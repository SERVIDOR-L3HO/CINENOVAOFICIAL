{
  "version": 2,
  "installCommand": "npm ci --prefer-offline=false",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
